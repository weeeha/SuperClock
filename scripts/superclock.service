[Unit]
Description=SuperClock Kiosk Browser
After=graphical.target nginx.service
Wants=nginx.service

[Service]
User=pi
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/pi/.Xauthority
ExecStartPre=/bin/sleep 5
ExecStart=/home/pi/SuperClock/scripts/kiosk.sh
Restart=always
RestartSec=5

[Install]
WantedBy=graphical.target
