# SuperClock configuration. Copy to .env and fill in.
# Variables prefixed VITE_ are exposed to the browser; everything else is server-only.

# GitHub stats app — personal access token with `read:user` scope.
VITE_GITHUB_TOKEN=

# Weather app — Open-Meteo lat/lon (no API key needed). Default unit is celsius.
VITE_WEATHER_LAT=
VITE_WEATHER_LON=
VITE_WEATHER_TZ=auto
# Set to `fahrenheit` to switch units; anything else = celsius.
VITE_WEATHER_UNIT=

# Calendar app — any iCal URL (Google Calendar `Secret address in iCal format`,
# iCloud subscription URL, Outlook .ics). Read by Express at request time, never
# exposed to the browser.
CALENDAR_ICS_URL=

# Admin panel — set to `true` on the single Pi that hosts the fleet admin
# (default: superclock-fast). When true, /api/admin/* and /admin/* are served
# and config/admin.json is consulted for bearer-token auth. Other Pis silently
# 404 admin routes.
ADMIN_HOST=false
