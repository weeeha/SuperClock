  "hat": {
    "model": "SunFounder Fusion HAT",
    "url": "https://www.sunfounder.com/products/sunfounder-fusion-hat-expansion-board",
    "eeprom_product_id": "0x0774",
    "eeprom_product_ver": "0x000a",
