  "audio": {
    "topology": "I2S DAC + I2S MEMS mic via SunFounder Fusion HAT",
    "alsa_card": "sndrpigooglevoi",
    "alsa_pcm": "hat",
    "speaker_amp_sysfs": "/sys/class/fusion_hat/fusion_hat/speaker",
    "test_speaker": "pico2wave -w /tmp/x.wav 'hello' && aplay -D hat /tmp/x.wav",
    "test_mic": "arecord -D hat -f S16_LE -r 16000 -c 1 -d 5 /tmp/r.wav"
  },
  "notes": "Round 1080x1080 circular display. Camera + mic + mono speaker all wired via Fusion HAT (also supplies the battery). Speaker amp is enabled on boot by /etc/systemd/system/fusion-hat-speaker.service."
